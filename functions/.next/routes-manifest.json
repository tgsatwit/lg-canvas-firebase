{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/videos/[id]",
      "regex": "^/api/videos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/videos/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/videos/[id]/confirm-details",
      "regex": "^/api/videos/([^/]+?)/confirm\\-details(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/videos/(?<nxtPid>[^/]+?)/confirm\\-details(?:/)?$"
    },
    {
      "page": "/api/videos/[id]/schedule",
      "regex": "^/api/videos/([^/]+?)/schedule(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/videos/(?<nxtPid>[^/]+?)/schedule(?:/)?$"
    },
    {
      "page": "/api/videos/[id]/schedule-upload",
      "regex": "^/api/videos/([^/]+?)/schedule\\-upload(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/videos/(?<nxtPid>[^/]+?)/schedule\\-upload(?:/)?$"
    },
    {
      "page": "/api/videos/[id]/upload-now",
      "regex": "^/api/videos/([^/]+?)/upload\\-now(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/videos/(?<nxtPid>[^/]+?)/upload\\-now(?:/)?$"
    },
    {
      "page": "/api/[..._path]",
      "regex": "^/api/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtP_path": "nxtP_path"
      },
      "namedRegex": "^/api/(?<nxtP_path>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/auth/login",
      "regex": "^/auth/login(?:/)?$",
