    {
      "page": "/dashboard/social",
      "regex": "^/dashboard/social(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/social(?:/)?$"
    },
    {
      "page": "/dashboard/social-monitor",
      "regex": "^/dashboard/social\\-monitor(?:/)?$",
      "routeKeys": {},
