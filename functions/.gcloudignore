# Compiled output
/lib/
/dist/
/build/

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Firebase cache
.firebase/

# Next.js cache and build files
.next/cache/
.next/trace
.next/standalone/node_modules/

# Exclude large Next.js build artifacts
.next/static/chunks/
.next/static/css/
.next/server/pages/
.next/server/chunks/

# TypeScript build info
*.tsbuildinfo

# Turbo
.turbo/

# Keep only essential Next.js files
!.next/standalone/
!.next/static/
!.next/server/app/ 