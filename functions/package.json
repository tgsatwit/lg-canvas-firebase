{
  "name": "functions",
  "description": "Cloud Functions for Firebase - Next.js API Routes",
  "scripts": {
    "build": "npm run build:next && npm run build:prep && npm run build:functions",
    "build:next": "cd ../apps/web && npm run build",
    "build:prep": "node scripts/build-next.js",
    "build:functions": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "next": "^15.3.1",
    "react": "^18",
    "react-dom": "^18",
    "@assistant-ui/react": "^0.7.68",
    "@blocknote/core": "^0.29.1",
    "@langchain/core": "^0.3.38",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.1.3",
    "@types/node": "^20.0.0",
    "firebase-functions-test": "^3.1.0",
    "fs-extra": "^11.0.0"
  },
  "private": true
}